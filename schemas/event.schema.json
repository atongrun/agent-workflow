{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-workflow.dev/schemas/event.schema.json",
  "title": "Event",
  "description": "Workflow event for Agent Bus integration.",
  "type": "object",
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": {
      "type": "string",
      "const": "agent-workflow/v1alpha1"
    },
    "kind": {
      "type": "string",
      "const": "Event"
    },
    "metadata": {
      "type": "object",
      "required": ["name", "version"],
      "properties": {
        "name": { "type": "string" },
        "version": { "type": "string" },
        "description": { "type": "string" }
      }
    },
    "spec": {
      "type": "object",
      "required": ["eventId", "eventType", "occurredAt", "workflowRunId", "producer"],
      "properties": {
        "eventId": { "type": "string" },
        "eventType": {
          "type": "string",
          "enum": [
            "workflow.run.created",
            "workflow.run.started",
            "workflow.run.completed",
            "workflow.run.failed",
            "workflow.stage.ready",
            "workflow.stage.started",
            "workflow.stage.waiting",
            "workflow.stage.completed",
            "workflow.stage.failed",
            "workflow.artifact.published",
            "workflow.decision.required",
            "workflow.decision.recorded",
            "workflow.memory.context.requested",
            "workflow.memory.context.available",
            "workflow.memory.write-candidates.published"
          ]
        },
        "schemaVersion": { "type": "string" },
        "occurredAt": { "type": "string", "format": "date-time" },
        "workflowRunId": { "type": "string" },
        "stageRunId": { "type": "string" },
        "taskId": { "type": "string" },
        "correlationId": { "type": "string" },
        "causationId": { "type": "string" },
        "producer": {
          "type": "object",
          "required": ["project", "component"],
          "properties": {
            "project": { "type": "string" },
            "component": { "type": "string" }
          }
        },
        "payload": { "type": "object" }
      }
    }
  }
}
