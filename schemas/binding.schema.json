{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-workflow.dev/schemas/binding.schema.json",
  "title": "BindingProfile",
  "description": "Maps roles to concrete runner configurations.",
  "type": "object",
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": {
      "type": "string",
      "const": "agent-workflow/v1alpha1"
    },
    "kind": {
      "type": "string",
      "const": "BindingProfile"
    },
    "metadata": {
      "type": "object",
      "required": ["name", "version"],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "version": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "labels": {
          "type": "object"
        }
      }
    },
    "spec": {
      "type": "object",
      "required": ["bindings"],
      "properties": {
        "bindings": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "required": ["runner"],
            "properties": {
              "runner": { "type": "string" },
              "model": { "type": "string" },
              "mode": { "type": "string" },
              "capabilities": {
                "type": "array",
                "items": { "type": "string" }
              },
              "limits": {
                "type": "object",
                "properties": {
                  "maxTokens": { "type": "integer" },
                  "timeoutSeconds": { "type": "integer" }
                }
              }
            }
          }
        }
      }
    }
  }
}
